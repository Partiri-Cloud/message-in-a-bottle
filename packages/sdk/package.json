{
  "name": "@partiri/message-in-a-bottle-sdk",
  "version": "0.1.1",
  "description": "Framework-agnostic notification SDK for message-in-a-bottle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/partiri-cloud/message-in-a-bottle.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
