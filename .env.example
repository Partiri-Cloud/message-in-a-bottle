# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=message_in_a_bottle

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Admin secret for /admin/* endpoints (required).
# Used to manage environments and API keys.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Server ports
API_PORT=3000
WS_PORT=3001

# AES-256-GCM key for encrypting integration credentials (64 hex chars = 32 bytes)
CREDENTIALS_ENCRYPTION_KEY=

# HMAC secret used to sign and verify subscriber tokens (required for WS server).
# Generate with: openssl rand -hex 32
SUBSCRIBER_HMAC_SECRET=

# Comma-separated list of allowed origins for WebSocket connections.
# If empty, all origins are accepted (not safe for production).
# Example: https://app.example.com,https://dashboard.example.com
WS_ALLOWED_ORIGINS=

# Maximum request body size in bytes for the API server (default: 2097152 = 2MB)
MAX_REQUEST_BODY_BYTES=2097152

# Data retention
NOTIFICATION_RETENTION_DAYS=90
ACTIVITY_LOG_RETENTION_DAYS=30

# Rate limits (JSON, per channel)
# RATE_LIMIT_CONFIG={"email":{"maxPerWindow":50,"windowMinutes":60},"sms":{"maxPerWindow":10,"windowMinutes":60},"push":{"maxPerWindow":100,"windowMinutes":60},"in_app":{"maxPerWindow":200,"windowMinutes":60},"slack":{"maxPerWindow":30,"windowMinutes":60},"ms_teams":{"maxPerWindow":30,"windowMinutes":60}}
